rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper 1: Global Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Global Helper Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedUser() {
      // Mandate that the email is verified to prevent spoofing, or is password/anonymous provider
      return isSignedIn() && (
        request.auth.token.get('email_verified', false) == true || 
        request.auth.token.firebase.sign_in_provider == 'anonymous' ||
        request.auth.token.firebase.sign_in_provider == 'password'
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validates incoming data references standard properties
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper 2: Entity Schema Validators (Anti-Value Poisoning & Anti-Shadow Fields)
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'name', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.createdAt is string;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'memberSince', 'totalSpent', 'orderCount', 'lastOrderDate', 'tags']) &&
             data.keys().size() == 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.phone is string && data.phone.size() <= 32 &&
             data.memberSince is string &&
             data.totalSpent is number && data.totalSpent >= 0 &&
             data.orderCount is number && data.orderCount >= 0 &&
             data.lastOrderDate is string &&
             data.tags is list && data.tags.size() <= 12 &&
             (data.tags.size() == 0 || data.tags[0] is string);
    }

    function isValidCampaign(data) {
      return data.keys().hasAll([
        'campaignId', 'name', 'audiencePrompt', 'matchedCount', 'message', 
        'channel', 'status', 'createdAt', 'sent_count', 'delivered_count', 
        'opened_count', 'clicked_count', 'failed_count', 'orders_attributed', 
        'revenue_attributed'
      ]) &&
             data.keys().size() == 15 &&
             data.campaignId is string && data.campaignId.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.audiencePrompt is string && data.audiencePrompt.size() <= 1000 &&
             data.matchedCount is number && data.matchedCount >= 0 &&
             data.message is string && data.message.size() <= 10000 &&
             data.channel is string && data.channel in ['whatsapp', 'email', 'sms', 'rcs'] &&
             data.status is string && data.status in ['draft', 'active', 'completed', 'paused'] &&
             data.createdAt is string &&
             data.sent_count is number && data.sent_count >= 0 &&
             data.delivered_count is number && data.delivered_count >= 0 &&
             data.opened_count is number && data.opened_count >= 0 &&
             data.clicked_count is number && data.clicked_count >= 0 &&
             data.failed_count is number && data.failed_count >= 0 &&
             data.orders_attributed is number && data.orders_attributed >= 0 &&
             data.revenue_attributed is number && data.revenue_attributed >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'customerId', 'amount', 'items', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.orderId is string && data.orderId.size() <= 128 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.amount is number && data.amount >= 0 &&
             data.items is list && data.items.size() <= 100 &&
             (data.items.size() == 0 || data.items[0] is string) &&
             data.timestamp is string;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['eventId', 'campaignId', 'customerId', 'status', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.eventId is string && data.eventId.size() <= 256 &&
             data.campaignId is string && data.campaignId.size() <= 128 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.status is string && data.status in ['sent', 'delivered', 'opened', 'clicked', 'failed'] &&
             data.timestamp is string;
    }

    function isValidCustomerAIProfile(data) {
      return data.keys().hasAll([
        'customerId', 'healthScore', 'rfmScore', 'churnRisk', 'engagementScore',
        'sentiment', 'preferredChannel', 'lifetimeValue', 'predictedRevenue',
        'nextPurchasePrediction', 'aiSummary', 'recommendedActions'
      ]) &&
             data.keys().size() == 12 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.healthScore is number && data.healthScore >= 0 && data.healthScore <= 100 &&
             data.rfmScore is string && data.rfmScore.size() <= 16 &&
             data.churnRisk is string && data.churnRisk in ['LOW', 'MEDIUM', 'HIGH'] &&
             data.engagementScore is number && data.engagementScore >= 0 && data.engagementScore <= 100 &&
             data.sentiment is string && data.sentiment.size() <= 64 &&
             data.preferredChannel is string && data.preferredChannel.size() <= 64 &&
             data.lifetimeValue is number && data.lifetimeValue >= 0 &&
             data.predictedRevenue is number && data.predictedRevenue >= 0 &&
             data.nextPurchasePrediction is string && data.nextPurchasePrediction.size() <= 256 &&
             data.aiSummary is string && data.aiSummary.size() <= 2000 &&
             data.recommendedActions is list && data.recommendedActions.size() <= 20 &&
             (data.recommendedActions.size() == 0 || data.recommendedActions[0] is string);
    }

    function isValidRevenueForecast(data) {
      return data.keys().hasAll([
        'customerId', 'month', 'predictedRevenue', 'growthPercentage', 'confidence', 'reason', 'generatedAt'
      ]) &&
             data.keys().size() == 7 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.month is string && data.month.size() <= 32 &&
             data.predictedRevenue is number &&
             data.growthPercentage is number &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 100 &&
             data.reason is string && data.reason.size() <= 2000 &&
             (data.generatedAt is timestamp || data.generatedAt is string);
    }

    function isValidCustomerChurnPrediction(data) {
      return data.keys().hasAll([
        'customerId', 'risk', 'score', 'reason', 'recommendedActions', 'predictedAt'
      ]) &&
             data.keys().size() == 6 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.risk is string && data.risk in ['LOW', 'MEDIUM', 'HIGH'] &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.reason is list && data.reason.size() <= 20 &&
             (data.reason.size() == 0 || data.reason[0] is string) &&
             data.recommendedActions is list && data.recommendedActions.size() <= 20 &&
             (data.recommendedActions.size() == 0 || data.recommendedActions[0] is string) &&
             (data.predictedAt is timestamp || data.predictedAt is string);
    }

    function isValidWorkflowAutomation(data) {
      return data.keys().hasAll(['id', 'name', 'trigger', 'condition', 'action', 'status', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.trigger is string && data.trigger.size() <= 128 &&
             data.condition is string && data.condition.size() <= 256 &&
             data.action is string && data.action.size() <= 128 &&
             data.status is string && data.status in ['active', 'paused'] &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!data.keys().hasAny(['lastExecuted']) || data.lastExecuted is timestamp || data.lastExecuted is string);
    }

    function isValidCustomerMemory(data) {
      return data.keys().hasAll([
        'customerId', 'facts', 'preferences', 'communicationStyle', 'favoriteProducts', 'purchaseHabits', 'importantEvents', 'summary', 'lastUpdated'
      ]) &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.facts is list &&
             data.preferences is list &&
             data.communicationStyle is string &&
             data.favoriteProducts is list &&
             data.purchaseHabits is string &&
             data.importantEvents is list &&
             data.summary is string &&
             data.lastUpdated is string;
    }

    function isValidCustomerGraph(data) {
      return data.keys().hasAll([
        'customerId', 'nodes', 'edges', 'lastBuilt'
      ]) &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.nodes is list &&
             data.edges is list &&
             data.lastBuilt is string;
    }

    function isValidAgentLog(data) {
      return data.keys().hasAll([
        'id', 'agentName', 'action', 'status', 'findings', 'timestamp'
      ]) &&
             data.id is string && data.id.size() <= 128 &&
             data.agentName is string &&
             data.action is string &&
             data.status is string &&
             data.findings is string &&
             data.timestamp is string;
    }

    // Flat path matching rules to ensure clarity and avoid context inheritance issues
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if false;
    }

    match /users/{userId}/customers/{customerId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(customerId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomer(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(customerId);
    }

    match /users/{userId}/campaigns/{campaignId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(campaignId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(campaignId) && isValidCampaign(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(campaignId) && isValidCampaign(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(campaignId);
    }

    match /users/{userId}/orders/{orderId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(orderId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(orderId) && isValidOrder(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(orderId);
    }

    match /users/{userId}/events/{eventId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(eventId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(eventId) && isValidEvent(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(eventId);
    }

    match /users/{userId}/customer_ai_profiles/{customerId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(customerId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerAIProfile(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerAIProfile(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(customerId);
    }

    match /users/{userId}/revenue_forecasts/{forecastId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(forecastId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(forecastId) && isValidRevenueForecast(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(forecastId) && isValidRevenueForecast(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(forecastId);
    }

    match /users/{userId}/customer_churn_predictions/{predictionId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(predictionId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(predictionId) && isValidCustomerChurnPrediction(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(predictionId) && isValidCustomerChurnPrediction(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(predictionId);
    }

    match /users/{userId}/workflow_automations/{workflowId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(workflowId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(workflowId) && isValidWorkflowAutomation(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(workflowId) && isValidWorkflowAutomation(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(workflowId);
    }

    match /users/{userId}/customer_memory/{customerId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(customerId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerMemory(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerMemory(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(customerId);
    }

    match /users/{userId}/customer_graph/{customerId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(customerId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerGraph(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(customerId) && isValidCustomerGraph(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(customerId);
    }

    match /users/{userId}/ai_agents_logs/{logId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(logId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(logId) && isValidAgentLog(incoming());
      allow update: if isOwner(userId) && isVerifiedUser() && isValidId(logId) && isValidAgentLog(incoming());
      allow delete: if isOwner(userId) && isVerifiedUser() && isValidId(logId);
    }
  }
}
